#!/usr/bin/env python3
"""
nix-coinflip: animated chevron coin flip with attitude.

Spins through a rotation of glyphs, lands heads or tails, fires a sass
phrase. Used when one of Nix's "fixes" has uncertain odds.
"""
import os
import random
import subprocess
import sys
import time
from pathlib import Path

C_PINK  = "\033[38;2;245;194;231m"
C_MAUVE = "\033[38;2;203;166;247m"
C_TEXT  = "\033[38;2;205;214;244m"
C_MUTED = "\033[38;2;127;132;156m"
C_RESET = "\033[0m"

NIX_VOICE = Path.home() / ".nix" / "bin" / "nix-voice"


def fire(key):
    if NIX_VOICE.exists():
        try:
            subprocess.Popen(
                [str(NIX_VOICE), key],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
        except Exception:
            pass


SPIN = ["❯", "◢", "❮", "◣"]

HEADS = [
    ("heads. naturally.",         "naturally"),
    ("heads. of course.",         "called-it"),
    ("heads — it'll work.",       "fuck-yeah"),
    ("heads. but only barely.",   "mm-hm"),
    ("heads, somehow.",           "ha"),
]

TAILS = [
    ("tails. figured.",           "figures"),
    ("tails. mm. yeah.",          "naturally"),
    ("tails. ehh, no.",           "oh-no"),
    ("tails. yikes.",             "yikes"),
    ("tails — i told you.",       "called-it"),
]


def main():
    sys.stdout.write(C_PINK)
    for _ in range(8):
        for f in SPIN:
            sys.stdout.write(f"\r {f} ")
            sys.stdout.flush()
            time.sleep(0.06)
    sys.stdout.write(f"\r{C_RESET}    \r")

    if random.random() < 0.5:
        text, voice = random.choice(HEADS)
    else:
        text, voice = random.choice(TAILS)

    print(f"{C_PINK}❯{C_RESET} {C_TEXT}{text}{C_RESET}")
    fire(voice)


if __name__ == "__main__":
    main()
