#!/usr/bin/env bash
# nix-pet-glyph: fast prompt helper.
#
# Reads ~/.nix/voice/.pet-state and prints "R;G;B GLYPH" — truecolor
# RGB triplet and a display string that reflects the pet's current
# state (mood, life stage, pending misbehavior, pending present).
# Applies decay-since-last-tick on the fly so the prompt stays accurate
# even if nix-pet hasn't been invoked in a while; the actual state
# file is left untouched (writes happen via nix-pet itself).
#
# Pure bash regex parsing of the JSON — no jq, no python, sub-ms.

set -u

state="$HOME/.nix/voice/.pet-state"

if [[ ! -f "$state" ]]; then
    echo "245;194;231 ❯"
    exit 0
fi

content=$(<"$state")

hunger=80
happy=80
alive="true"
born=0
last_decay=0

[[ $content =~ \"hunger\":[[:space:]]*([0-9]+) ]]      && hunger=${BASH_REMATCH[1]}
[[ $content =~ \"happiness\":[[:space:]]*([0-9]+) ]]   && happy=${BASH_REMATCH[1]}
[[ $content =~ \"alive\":[[:space:]]*(true|false) ]]   && alive=${BASH_REMATCH[1]}
[[ $content =~ \"born\":[[:space:]]*([0-9]+) ]]        && born=${BASH_REMATCH[1]}
[[ $content =~ \"last_decay\":[[:space:]]*([0-9]+) ]]  && last_decay=${BASH_REMATCH[1]}

# Indicators for pending misbehavior / present
misbehaving=0
presenting=0
[[ $content =~ \"recent_misbehavior\":[[:space:]]*\{ ]] && misbehaving=1
[[ $content =~ \"recent_present\":[[:space:]]*\{ ]] && presenting=1

if [[ "$alive" == "false" ]]; then
    echo "127;132;156 ✕"
    exit 0
fi

now=$(date +%s)

# Egg state: yellow `o`, no stats
age_hours=$(( (now - born) / 3600 ))
if (( age_hours < 6 )); then
    echo "249;226;175 o"
    exit 0
fi

# Apply on-the-fly decay (display only, don't write back)
elapsed=$(( now - last_decay ))
hours=$(( elapsed / 3600 ))
hunger=$(( hunger - hours ))
(( hunger < 0 )) && hunger=0
happy=$(( happy - hours / 2 ))
(( happy < 0 )) && happy=0

score=$(( (hunger + happy) / 2 ))

if   (( score >= 70 )); then rgb="245;194;231"; glyph="❯"
elif (( score >= 50 )); then rgb="203;166;247"; glyph="❯"
elif (( score >= 30 )); then rgb="249;226;175"; glyph=">"
elif (( score >= 10 )); then rgb="243;139;168"; glyph=">"
else                         rgb="243;139;168"; glyph="·"
fi

# Append markers for pending state
(( misbehaving )) && glyph="${glyph}!"
(( presenting )) && glyph="${glyph}+"

echo "$rgb $glyph"
