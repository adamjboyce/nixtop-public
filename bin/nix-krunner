_VOLUME_SET_PATTERN = re.compile(r"^(?:volume|vol)\s+(\d{1,3})%?$", re.IGNORECASE)


def try_action(q):
    ql = q.lower().strip()
    entry = ACTIONS.get(ql)
    if entry:
        handler, label, icon = entry
        return (ql, label, icon)

    # Pattern: "volume 50" / "vol 75%" → volume-set-<N>
    m = _VOLUME_SET_PATTERN.match(ql)
    if m:
        pct = max(0, min(100, int(m.group(1))))
        return (f"volume-set-{pct}", f"volume to {pct}%", "audio-volume-high")

    return None


# ─── pass-through detectors ─────────────────────────────────────

def is_single_word_app(q):
    if " " in q:
        return False
    if len(q) < 2:
        return False
    return shutil.which(q) is not None


def is_path_query(q):
    if q.startswith(("/", "~/", "./", "../")):
        return True
    if q == "~":
        return True
    if re.match(r"^\.[\w\-]+$", q):
        return True
    return False


# ─── DBus service ───────────────────────────────────────────────

class NixRunner(dbus.service.Object):
    def __init__(self, bus_name):
        super().__init__(bus_name, OBJ_PATH)

    @dbus.service.method(
        IFACE,
        in_signature="s",
        out_signature="a(sssida{sv})",
    )
    def Match(self, query):
        q = (query or "").strip()
        if len(q) < MIN_QUERY_LEN:
            return []

        # 1. Math
        math_result = try_math(q)
        if math_result is not None:
            return [self._math_match(q, math_result)]

        # 2. Unit conversion
        unit_result = try_unit(q)
        if unit_result is not None:
            return [self._unit_match(unit_result)]

        # 3. State query
        state_result = try_state_query(q)
        if state_result is not None:
            text, icon = state_result
            return [self._state_match(q, text, icon)]

        # 4. Action
        action_result = try_action(q)
        if action_result is not None:
            key, label, icon = action_result
            return [self._action_match(key, label, icon)]

        # 5. Pass-through: single-word binary
        if is_single_word_app(q):
            return []

        # 6. Pass-through: path-like
        if is_path_query(q):
            return []

        # 7. Fallback: ask nix
        return [self._ask_nix_match(q)]

    @dbus.service.method(IFACE, out_signature="a(sss)")
    def Actions(self):
        return []

    @dbus.service.method(IFACE, in_signature="ss")
    def Run(self, match_id, action_id):
        if match_id.startswith("math::"):
            payload = match_id[len("math::"):]
            if "=" in payload:
                _, result = payload.rsplit("=", 1)
                self._copy_clipboard(result.strip())
            return

        if match_id.startswith("unit::"):
            payload = match_id[len("unit::"):]
            if " = " in payload:
                _, result = payload.split(" = ", 1)
                self._copy_clipboard(result.strip())
            return

        if match_id.startswith("state::"):
            # state::<key>|<cached-text>  — copy the cached text
            payload = match_id[len("state::"):]
            if "|" in payload:
                _, cached = payload.split("|", 1)
                self._copy_clipboard(cached.strip())
            return

        if match_id.startswith("action::"):
            key = match_id[len("action::"):]
            # Pattern-based volume-set: "volume-set-<N>"
            if key.startswith("volume-set-"):
                try:
                    pct = int(key[len("volume-set-"):])
                    _a_volume_set(pct)
                except Exception:
                    pass
                return
            entry = ACTIONS.get(key.lower())
            if entry:
                handler = entry[0]
                try:
                    handler()
                except Exception:
                    pass
            return

        if match_id.startswith("nix::"):
            query = match_id[len("nix::"):]
            if not query:
                return
            self._summon_nix(query)
            return

    @dbus.service.method(IFACE)
    def Teardown(self):
        pass

    # ─── match builders ─────────────────────────────────────

    def _math_match(self, q, result):
        return (
            f"math::{q}={result}",
            f"{q} = {result}",
            "accessories-calculator",
            dbus.Int32(100),
            1.0,
            dbus.Dictionary({"subtext": "press enter to copy result"}, signature="sv"),
        )

    def _unit_match(self, result):
        return (
            f"unit::{result}",
            result,
            "accessories-calculator",
            dbus.Int32(100),
            1.0,
            dbus.Dictionary({"subtext": "press enter to copy result"}, signature="sv"),
        )

    def _state_match(self, key, text, icon):
        return (
            f"state::{key}|{text}",
            text,
            icon,
            dbus.Int32(100),
            1.0,
            dbus.Dictionary({"subtext": "press enter to copy"}, signature="sv"),
        )

    def _action_match(self, key, label, icon):
        return (
            f"action::{key}",
            f"▸ {label}",
            icon,
            dbus.Int32(100),
            1.0,
            dbus.Dictionary({"subtext": "press enter to execute"}, signature="sv"),
        )

    def _ask_nix_match(self, q):
        return (
            f"nix::{q}",
            f"ask nix: {q}",
            "utilities-terminal",
            dbus.Int32(70),
            0.8,
            dbus.Dictionary({"subtext": "summon nix with this question"}, signature="sv"),
        )

    # ─── action helpers ─────────────────────────────────────

    def _copy_clipboard(self, text):
        try:
            subprocess.run(
                ["xclip", "-selection", "clipboard", "-i"],
                input=text, text=True, timeout=1, check=False,
            )
            subprocess.run(
                ["xclip", "-selection", "primary", "-i"],
                input=text, text=True, timeout=1, check=False,
            )
        except Exception:
            pass

    def _summon_nix(self, query):
        os.makedirs(os.path.dirname(PENDING), exist_ok=True)
        with open(PENDING, "w") as f:
            f.write(query)

        yakuake_visible = self._yakuake_visible()

        if not yakuake_visible and os.access(CAPTURE, os.X_OK):
            self._call([CAPTURE])

        self._call(["qdbus6", "org.kde.yakuake", "/yakuake/sessions", "addSession"])

        if not yakuake_visible:
            self._call(
                ["qdbus6", "org.kde.yakuake", "/yakuake/window", "toggleWindowState"]
            )

    def _yakuake_visible(self):
        try:
            r = subprocess.run(
                ["xdotool", "search", "--onlyvisible", "--class", "yakuake"],
                capture_output=True, text=True, timeout=1,
            )
            return bool(r.stdout.strip())
        except Exception:
            return False

    def _call(self, argv):
        try:
            subprocess.run(
                argv, timeout=2, check=False,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
        except Exception:
            pass


def main():
    DBusGMainLoop(set_as_default=True)
    bus = dbus.SessionBus()
    name = dbus.service.BusName(BUS_NAME, bus=bus)
    NixRunner(name)
    GLib.MainLoop().run()


if __name__ == "__main__":
    main()
