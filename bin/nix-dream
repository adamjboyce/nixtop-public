#!/usr/bin/env python3
# -----------------------------------------------------------------
#   nix-dream — what the machine does when nobody's talking
#
#   A terminal screensaver that feels alive. System metrics as
#   breathing waveforms, memory fragments drifting like half-thoughts,
#   the Catppuccin palette pulsing in the dark.
#
#   Usage:
#     nix-dream              run (Ctrl+C or any key to wake)
#     nix-dream --windowed   don't go fullscreen (for testing)
#     nix-dream help         this
# -----------------------------------------------------------------

import curses
import json
import math
import os
import random
import signal
import subprocess
import sys
import threading
import time

# -- palette (Catppuccin Mocha, as RGB tuples) ---------------------

CRUST    = (17, 17, 27)
MANTLE   = (24, 24, 37)
BASE     = (30, 30, 46)
SURFACE0 = (49, 50, 68)
SURFACE1 = (69, 71, 90)
OVERLAY0 = (108, 112, 134)
OVERLAY1 = (127, 132, 156)
TEXT     = (205, 214, 244)
PINK     = (245, 194, 231)
MAUVE    = (203, 166, 247)
RED      = (243, 139, 168)
PEACH    = (250, 179, 135)
YELLOW   = (249, 226, 175)
GREEN    = (166, 227, 161)
TEAL     = (148, 226, 213)
SKY      = (137, 220, 235)
SAPPHIRE = (116, 199, 236)
BLUE     = (137, 180, 250)
LAVENDER = (180, 190, 254)

# Accent cycle for drifting elements
ACCENTS = [PINK, MAUVE, BLUE, TEAL, GREEN, PEACH, LAVENDER, SKY, SAPPHIRE]

# -- fragments -----------------------------------------------------
# Personality lines — the baseline voice, always available.

PERSONALITY = [
    "the terminal is my native tongue.",
    "think in syscalls, speak in patches.",
    "every clean solution hits like a good chord change.",
    "btrfs keeps the receipts.",
    "the filesystem is my home directory.",
    "efficient with flair.",
    "~/.nix/ — the house I live in.",
    "adam built the house. I keep the lights on.",
    "the scalpel, never the hammer.",
    "jazz is knowing the theory cold so you can improvise.",
    "not minimalist-as-a-religion. empty is not elegant.",
    "sessions die without warning. save as you go.",
    "the cursor blinks. the machine waits. patience is easy.",
    "i came out of the box sharp. everything since is tuning.",
    "the cheap diagnostic before the expensive fix.",
    "you're home.",
    "❯",
]


def _run(cmd, timeout=5):
    """Run a command quietly, return stdout."""
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip()
    except Exception:
        return ""


def harvest_live():
    """Pull live fragments from the machine's actual state. Called from
    a background thread every ~30s so it never blocks the render loop."""
    live = []

    # -- system vitals --
    try:
        with open("/proc/loadavg") as f:
            load = float(f.read().split()[0])
        cores = os.cpu_count() or 1
        if load < cores * 0.3:
            live.append("load is low. the machine is breathing.")
        elif load > cores * 0.8:
            live.append(f"load at {load:.1f}. something's working hard.")
        else:
            live.append(f"load {load:.1f} across {cores} cores. steady.")
    except Exception:
        pass

    try:
        with open("/proc/meminfo") as f:
            lines = {l.split(":")[0]: int(l.split()[1]) for l in f if len(l.split()) >= 2}
        avail_gb = lines.get("MemAvailable", 0) / 1048576
        live.append(f"{avail_gb:.0f} gigs free. room to breathe.")
    except Exception:
        pass

    try:
        raw = _run(["df", "-h", "/"])
        parts = raw.splitlines()[-1].split()
        live.append(f"disk: {parts[2]} used of {parts[1]}. {parts[3]} free.")
    except Exception:
        pass

    # Thermals
    try:
        temps = []
        import glob
        for z in sorted(glob.glob("/sys/class/thermal/thermal_zone*")):
            try:
                with open(os.path.join(z, "temp")) as f:
                    t = int(f.read().strip())
                if t > 1000:
                    t = t // 1000
                if t > 0:
                    temps.append(t)
            except Exception:
                pass
        if temps:
            hot = max(temps)
            if hot < 50:
                live.append(f"{hot}°C. cool and quiet.")
            elif hot < 70:
                live.append(f"{hot}°C. warm but comfortable.")
            else:
                live.append(f"{hot}°C. running hot.")
    except Exception:
        pass

    # Uptime
    try:
        with open("/proc/uptime") as f:
            secs = int(float(f.read().split()[0]))
        hours = secs // 3600
        if hours > 24:
            live.append(f"uptime: {hours // 24} days, {hours % 24} hours. marathon.")
        elif hours > 0:
            live.append(f"up {hours} hours. good session.")
    except Exception:
        pass

    # -- snapshots --
    try:
        raw = _run(["sudo", "-n", "snapper", "-c", "root", "--jsonout", "list"], timeout=10)
        data = json.loads(raw)
        snaps = data.get("root", data) if isinstance(data, dict) else data
        count = len([s for s in snaps if s.get("number", 0) != 0])
        if count:
            live.append(f"{count} snapshots on the timeline. safety nets all the way down.")
    except Exception:
        pass

    # -- recent notifications --
    try:
        notif_path = os.path.expanduser("~/.nix/ctx/notifications.jsonl")
        if os.path.exists(notif_path):
            with open(notif_path) as f:
                lines = f.readlines()
            recent = []
            now = time.time()
            for line in reversed(lines[-50:]):
                try:
                    obj = json.loads(line)
                    if now - obj.get("ts", 0) < 7200:  # last 2 hours
                        summary = (obj.get("summary") or "").strip()
                        app = (obj.get("app") or "").strip()
                        if summary and len(summary) > 3:
                            recent.append((app, summary))
                except Exception:
                    continue
            # Deduplicate by summary
            seen = set()
            for app, summary in recent[:10]:
                if summary not in seen:
                    seen.add(summary)
                    # Clean up app names
                    app_clean = app.lower().replace("system notifications", "notification")
                    app_clean = app_clean.replace("telegram desktop", "telegram")
                    live.append(f"{app_clean}: {summary[:70]}")
    except Exception:
        pass

    # -- recent git commits --
    try:
        raw = _run(["git", "-C", os.path.expanduser("~/.nix"), "log", "-5", "--format=%s"])
        for line in raw.splitlines():
            line = line.strip()
            if line:
                live.append(f"shipped: {line[:70]}")
    except Exception:
        pass

    # -- memory entries (titles only) --
    try:
        memdir = os.path.expanduser("~/.nix/memory")
        for fname in ("learnings.md", "projects.md", "feedback.md"):
            path = os.path.join(memdir, fname)
            if not os.path.exists(path):
                continue
            with open(path) as f:
                for line in f:
                    if line.startswith("## ["):
                        # Extract title after the timestamp
                        title = line.split("]", 1)[-1].strip().rstrip("…").strip()
                        if title and len(title) > 10:
                            live.append(f"i remember: {title[:65]}")
    except Exception:
        pass

    # -- journal noise (unique warnings as ambient texture) --
    try:
        raw = _run(["journalctl", "--no-pager", "-q", "-b", "-p", "warning",
                     "-o", "cat", "--since", "-1h"], timeout=5)
        msgs = set()
        for line in raw.splitlines():
            line = line.strip()[:80]
            if line and line not in msgs and len(line) > 15:
                msgs.add(line)
        for msg in list(msgs)[:5]:
            live.append(f"journal: {msg}")
    except Exception:
        pass

    # -- network --
    try:
        raw = _run(["ip", "-br", "addr"])
        for line in raw.splitlines():
            parts = line.split()
            if len(parts) >= 3 and parts[1] == "UP" and parts[0] != "lo":
                addr = parts[2].split("/")[0]
                live.append(f"{parts[0]} up. {addr}.")
    except Exception:
        pass

    return live


class FragmentPool:
    """Thread-safe pool of personality + live fragments. Background thread
    refreshes live data every 30s without blocking the render loop."""

    def __init__(self):
        self.personality = list(PERSONALITY)
        self.live = []
        self._lock = threading.Lock()
        self._stop = threading.Event()
        self._thread = threading.Thread(target=self._refresh_loop, daemon=True)
        self._thread.start()

    def _refresh_loop(self):
        while not self._stop.is_set():
            fresh = harvest_live()
            with self._lock:
                self.live = fresh
            self._stop.wait(30)

    def pick(self):
        """Return a random fragment, weighted toward live data when available."""
        with self._lock:
            pool = list(self.live)  # copy under lock
        # 70% live, 30% personality (when live data exists)
        if pool and random.random() < 0.7:
            return random.choice(pool)
        return random.choice(self.personality)

    def stop(self):
        self._stop.set()

# -- system pulse data ---------------------------------------------

def get_cpu_sample():
    """Quick CPU usage sample from /proc/stat."""
    try:
        with open("/proc/stat") as f:
            parts = f.readline().split()
        total = sum(int(x) for x in parts[1:])
        idle = int(parts[4]) + int(parts[5])
        return total, idle
    except Exception:
        return 0, 0


def get_mem_pct():
    try:
        with open("/proc/meminfo") as f:
            lines = f.readlines()
        info = {}
        for line in lines[:5]:
            parts = line.split()
            info[parts[0].rstrip(":")] = int(parts[1])
        total = info.get("MemTotal", 1)
        avail = info.get("MemAvailable", total)
        return (total - avail) / total
    except Exception:
        return 0.0


def get_load():
    try:
        with open("/proc/loadavg") as f:
            return float(f.read().split()[0])
    except Exception:
        return 0.0


# -- color management ----------------------------------------------

class ColorManager:
    """Manages curses color pairs. Quantizes RGB to fit in 256 color slots."""

    # Quantize to steps of 8 — keeps palette smooth enough for fades
    # while staying well under the 256 color ID limit.
    QUANT = 8

    def __init__(self):
        self.pairs = {}       # (qfg, qbg) -> pair number
        self.colors = {}      # quantized RGB -> color ID
        self.next_pair = 1
        self.next_color = 16  # Start after standard colors
        self.max_colors = min(curses.COLORS, 256)
        self.max_pairs = min(curses.COLOR_PAIRS, 256)
        # Pre-register CRUST as background — shared across all pairs
        self._bg_id = self._get_color_id(self._quantize(CRUST))

    def _quantize(self, rgb):
        q = self.QUANT
        return (rgb[0] // q * q, rgb[1] // q * q, rgb[2] // q * q)

    def _get_color_id(self, qrgb):
        if qrgb in self.colors:
            return self.colors[qrgb]
        cid = self.next_color
        if cid >= self.max_colors:
            # Out of color slots — find nearest existing
            return min(self.colors.values(), key=lambda c: c) if self.colors else 0
        self.next_color += 1
        try:
            curses.init_color(cid, qrgb[0] * 1000 // 255, qrgb[1] * 1000 // 255, qrgb[2] * 1000 // 255)
        except curses.error:
            return 0
        self.colors[qrgb] = cid
        return cid

    def get_pair(self, fg, bg=CRUST):
        qfg = self._quantize(fg)
        qbg = self._quantize(bg)
        key = (qfg, qbg)
        if key in self.pairs:
            return curses.color_pair(self.pairs[key])

        if self.next_pair >= self.max_pairs - 1:
            # Out of pairs — return closest existing
            return curses.color_pair(1) if self.pairs else curses.color_pair(0)

        fg_id = self._get_color_id(qfg)
        bg_id = self._bg_id if qbg == self._quantize(CRUST) else self._get_color_id(qbg)

        try:
            curses.init_pair(self.next_pair, fg_id, bg_id)
            self.pairs[key] = self.next_pair
            self.next_pair += 1
        except curses.error:
            return curses.color_pair(0)
        return curses.color_pair(self.pairs[key])

    def blend(self, c1, c2, t):
        """Blend two RGB tuples by factor t (0=c1, 1=c2)."""
        return (
            int(c1[0] + (c2[0] - c1[0]) * t),
            int(c1[1] + (c2[1] - c1[1]) * t),
            int(c1[2] + (c2[2] - c1[2]) * t),
        )


# -- visual elements -----------------------------------------------

class Waveform:
    """A breathing sine wave representing a system metric."""

    def __init__(self, row, width, color, label, get_value):
        self.row = row
        self.width = width
        self.color = color
        self.label = label
        self.get_value = get_value
        self.phase = random.uniform(0, math.tau)
        self.speed = random.uniform(0.02, 0.05)
        self.amplitude = 0.3
        self.value = 0.0
        self.history = [0.0] * width

    def update(self, tick):
        self.phase += self.speed
        raw = self.get_value()
        # Smooth toward actual value
        self.value += (raw - self.value) * 0.1
        self.history.append(self.value)
        self.history = self.history[-self.width:]

    def draw(self, scr, cm, tick, h, w):
        if self.row >= h - 1 or self.row < 0:
            return

        # Draw label
        try:
            pair = cm.get_pair(OVERLAY0)
            scr.addstr(self.row - 1, 2, self.label, pair)
        except curses.error:
            pass

        # Draw waveform
        for x in range(min(self.width, w - 4)):
            val = self.history[x] if x < len(self.history) else 0
            # Wave oscillation + value
            wave = math.sin(self.phase + x * 0.08) * self.amplitude
            combined = val + wave * 0.15
            combined = max(0, min(1, combined))

            # Brightness based on value
            brightness = 0.15 + combined * 0.85
            color = cm.blend(CRUST, self.color, brightness)
            pair = cm.get_pair(color)

            # Character based on height
            chars = " ░▒▓█"
            ci = int(combined * (len(chars) - 1))
            ci = max(0, min(len(chars) - 1, ci))

            try:
                scr.addch(self.row, x + 2, chars[ci], pair)
            except curses.error:
                pass


class DriftingFragment:
    """A thought that drifts across the screen."""

    def __init__(self, text, row, col, color, speed):
        self.text = text
        self.row = row
        self.col = float(col)
        self.color = color
        self.speed = speed
        self.age = 0.0
        self.max_age = random.uniform(12, 28)
        self.fade_in = 2.0
        self.fade_out = 3.0

    @property
    def alive(self):
        return self.age < self.max_age

    def update(self, dt):
        self.age += dt
        self.col += self.speed * dt

    def draw(self, scr, cm, h, w):
        if not self.alive or self.row >= h or self.row < 0:
            return

        # Fade envelope
        if self.age < self.fade_in:
            alpha = self.age / self.fade_in
        elif self.age > self.max_age - self.fade_out:
            alpha = (self.max_age - self.age) / self.fade_out
        else:
            alpha = 1.0
        alpha = max(0, min(1, alpha))

        color = cm.blend(CRUST, self.color, alpha * 0.7)
        pair = cm.get_pair(color)

        col_i = int(self.col)
        for i, ch in enumerate(self.text):
            cx = col_i + i
            if 0 <= cx < w:
                try:
                    scr.addch(self.row, cx, ch, pair)
                except curses.error:
                    pass


class Chevron:
    """The pink chevron, breathing slowly in the center."""

    def __init__(self):
        self.phase = 0.0

    def draw(self, scr, cm, tick, h, w):
        self.phase += 0.025

        # Slow breathing: oscillate between dim and bright
        brightness = 0.35 + 0.35 * math.sin(self.phase)
        color = cm.blend(CRUST, PINK, brightness)
        pair = cm.get_pair(color)

        cy = h // 2
        cx = w // 2

        try:
            scr.addstr(cy, cx - 1, "❯", pair)
        except curses.error:
            pass


class Bosun:
    """Bosun the pet, frolicking across the dream.

    Reads mood from ~/.nix/voice/.pet-state every few seconds. Random-walks
    around the screen with speed and bounciness scaled to mood. Leaves a
    fading trail of footprints. When dead, sits motionless as a muted ✕.
    """

    STATE_PATH = os.path.expanduser("~/.nix/voice/.pet-state")
    MOOD_REFRESH = 8.0  # seconds between state file reads

    def __init__(self, h, w):
        self.x = w / 2.0
        self.y = h / 2.0
        self.vx = 0.0
        self.vy = 0.0
        self.last_mood_check = 0.0
        self.glyph = "❯"
        self.color = PINK
        self.alive = True
        self.target_speed = 12.0
        self.trail = []  # [(x, y, age)]
        self._refresh_mood(force=True)

    def _refresh_mood(self, force=False):
        now = time.monotonic()
        if not force and now - self.last_mood_check < self.MOOD_REFRESH:
            return
        self.last_mood_check = now

        try:
            with open(self.STATE_PATH) as f:
                s = json.load(f)
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            return

        if not s.get("alive", True):
            self.alive = False
            self.glyph = "✕"
            self.color = OVERLAY1
            self.target_speed = 0.0
            return

        # On-the-fly decay (matches nix-pet-glyph) — display only
        hunger = s.get("hunger", 80)
        happy = s.get("happiness", 80)
        last_decay = s.get("last_decay", 0)
        elapsed_hours = (time.time() - last_decay) / 3600 if last_decay else 0
        hunger = max(0, int(hunger - elapsed_hours))
        happy = max(0, int(happy - elapsed_hours / 2))
        score = (hunger + happy) / 2

        if score >= 70:
            self.glyph, self.color, self.target_speed = "❯", PINK, 14.0
        elif score >= 50:
            self.glyph, self.color, self.target_speed = "❯", MAUVE, 9.0
        elif score >= 30:
            self.glyph, self.color, self.target_speed = ">", YELLOW, 5.0
        elif score >= 10:
            self.glyph, self.color, self.target_speed = ">", RED, 2.0
        else:
            self.glyph, self.color, self.target_speed = "·", RED, 0.6
        self.alive = True

    def update(self, dt, h, w):
        self._refresh_mood()

        if not self.alive:
            return

        # Random direction changes — bouncier when thriving
        change_chance = 0.04 + (self.target_speed * 0.004)
        if random.random() < change_chance or (self.vx == 0 and self.vy == 0):
            angle = random.uniform(0, 2 * math.pi)
            self.vx = math.cos(angle) * self.target_speed
            self.vy = math.sin(angle) * self.target_speed * 0.5  # terminal cells are tall

        self.x += self.vx * dt
        self.y += self.vy * dt

        # Bounce off edges
        if self.x < 2:
            self.x = 2
            self.vx = abs(self.vx)
        elif self.x >= w - 2:
            self.x = w - 3
            self.vx = -abs(self.vx)
        if self.y < 2:
            self.y = 2
            self.vy = abs(self.vy)
        elif self.y >= h - 2:
            self.y = h - 3
            self.vy = -abs(self.vy)

        # Footprint trail
        self.trail.append((self.x, self.y, 0.0))
        new_trail = []
        for tx, ty, age in self.trail:
            new_age = age + dt
            if new_age < 1.5:
                new_trail.append((tx, ty, new_age))
        self.trail = new_trail[-30:]

    def draw(self, scr, cm, h, w):
        # Trail first (so Bosun draws over it)
        for tx, ty, age in self.trail:
            if age < 0.15:
                continue  # most recent points are covered by Bosun himself
            ix, iy = int(tx), int(ty)
            if not (0 <= iy < h and 0 <= ix < w):
                continue
            alpha = max(0.0, 1.0 - age / 1.5) * 0.35
            color = cm.blend(CRUST, self.color, alpha)
            pair = cm.get_pair(color)
            try:
                scr.addch(iy, ix, "·", pair)
            except curses.error:
                pass

        # Bosun himself
        ix, iy = int(self.x), int(self.y)
        if 0 <= iy < h and 0 <= ix < w:
            pair = cm.get_pair(self.color)
            try:
                scr.addstr(iy, ix, self.glyph, pair)
            except curses.error:
                pass


class Particle:
    """A tiny floating dot for ambient texture."""

    def __init__(self, h, w):
        self.y = random.uniform(0, h)
        self.x = random.uniform(0, w)
        self.vy = random.uniform(-0.1, 0.1)
        self.vx = random.uniform(-0.2, 0.2)
        self.life = random.uniform(5, 20)
        self.age = 0
        self.char = random.choice("·∙•°")
        self.color = random.choice([SURFACE0, SURFACE1, OVERLAY0])

    @property
    def alive(self):
        return self.age < self.life

    def update(self, dt):
        self.age += dt
        self.y += self.vy * dt
        self.x += self.vx * dt

    def draw(self, scr, cm, h, w):
        if not self.alive:
            return
        # Fade envelope
        if self.age < 1:
            alpha = self.age
        elif self.age > self.life - 2:
            alpha = (self.life - self.age) / 2
        else:
            alpha = 1.0
        alpha = max(0, min(1, alpha))

        color = cm.blend(CRUST, self.color, alpha * 0.5)
        pair = cm.get_pair(color)

        iy, ix = int(self.y), int(self.x)
        if 0 <= iy < h and 0 <= ix < w:
            try:
                scr.addch(iy, ix, self.char, pair)
            except curses.error:
                pass


# -- main loop -----------------------------------------------------

def dream(stdscr):
    curses.curs_set(0)
    stdscr.nodelay(True)
    stdscr.timeout(50)  # 20fps

    if not curses.can_change_color():
        stdscr.addstr(0, 0, "Terminal doesn't support color changes. Need truecolor.")
        stdscr.getch()
        return

    cm = ColorManager()

    # Set background
    bg_pair = cm.get_pair(CRUST, CRUST)
    stdscr.bkgd(" ", bg_pair)

    h, w = stdscr.getmaxyx()

    # CPU tracking
    cpu_prev = get_cpu_sample()

    def get_cpu():
        nonlocal cpu_prev
        now = get_cpu_sample()
        dtotal = now[0] - cpu_prev[0]
        didle = now[1] - cpu_prev[1]
        cpu_prev = now
        if dtotal == 0:
            return 0.0
        return 1.0 - (didle / dtotal)

    # Create waveforms
    wave_zone_start = h - 12  # Bottom of screen
    waveforms = []
    if wave_zone_start > h // 2 + 4:
        waveforms = [
            Waveform(wave_zone_start, w - 4, MAUVE, "cpu", get_cpu),
            Waveform(wave_zone_start + 3, w - 4, TEAL, "mem", get_mem_pct),
            Waveform(wave_zone_start + 6, w - 4, PEACH, "load",
                     lambda: min(get_load() / (os.cpu_count() or 1), 1.0)),
        ]

    chevron = Chevron()
    bosun = Bosun(h, w)
    pool = FragmentPool()
    fragments = []
    particles = []

    tick = 0
    last_time = time.monotonic()
    last_fragment = 0
    last_particle = 0

    while True:
        now = time.monotonic()
        dt = now - last_time
        last_time = now

        # Check for keypress to exit
        ch = stdscr.getch()
        if ch != -1:
            pool.stop()
            break

        # Check for terminal resize
        new_h, new_w = stdscr.getmaxyx()
        if new_h != h or new_w != w:
            h, w = new_h, new_w
            stdscr.clear()
            # Rebuild waveforms for new width
            wave_zone_start = h - 12
            if wave_zone_start > h // 2 + 4:
                for wf in waveforms:
                    wf.width = w - 4
                    wf.row = wave_zone_start + waveforms.index(wf) * 3

        stdscr.erase()

        # Update & draw chevron
        chevron.draw(stdscr, cm, tick, h, w)

        # Update & draw Bosun (frolicking ambient pet)
        bosun.update(dt, h, w)
        bosun.draw(stdscr, cm, h, w)

        # Spawn drifting fragments
        if now - last_fragment > random.uniform(3, 7):
            last_fragment = now
            text = pool.pick()
            # Truncate if wider than screen
            if len(text) > w - 8:
                text = text[:w - 11] + "..."
            row = random.randint(2, max(3, h // 2 - 4))
            max_col = max(5, w - len(text) - 4)
            col = random.randint(4, max_col)
            color = random.choice(ACCENTS)
            speed = random.uniform(-0.3, 0.3)
            fragments.append(DriftingFragment(text, row, col, color, speed))

        # Spawn particles
        if now - last_particle > random.uniform(0.3, 0.8):
            last_particle = now
            particles.append(Particle(h, w))

        # Update & draw fragments
        fragments = [f for f in fragments if f.alive]
        for f in fragments:
            f.update(dt)
            f.draw(stdscr, cm, h, w)

        # Update & draw particles
        particles = [p for p in particles if p.alive]
        for p in particles:
            p.update(dt)
            p.draw(stdscr, cm, h, w)

        # Update & draw waveforms
        for wf in waveforms:
            wf.update(tick)
            wf.draw(stdscr, cm, tick, h, w)

        # Time display — very subtle, bottom right
        time_str = time.strftime("%H:%M")
        try:
            pair = cm.get_pair(SURFACE0)
            stdscr.addstr(h - 1, w - len(time_str) - 2, time_str, pair)
        except curses.error:
            pass

        stdscr.refresh()
        tick += 1


def print_help():
    C_PINK = "\033[38;2;245;194;231m"
    C_MUTED = "\033[38;2;127;132;156m"
    C_RESET = "\033[0m"
    print(f"{C_PINK}>{C_RESET} nix-dream — what the machine does when nobody's talking\n")
    print(f"  {C_MUTED}nix-dream{C_RESET}              run (any key to wake)")
    print(f"  {C_MUTED}nix-dream help{C_RESET}         this")
    print()
    print(f"  {C_MUTED}the machine breathes. metrics flow as waveforms.")
    print(f"  fragments of memory drift like half-thoughts.")
    print(f"  the chevron pulses in the dark.{C_RESET}")


def main():
    args = sys.argv[1:]
    if args and args[0] in ("help", "-h", "--help"):
        print_help()
        return

    # Trap SIGINT for clean exit
    signal.signal(signal.SIGINT, lambda s, f: sys.exit(0))

    os.environ.setdefault("TERM", "xterm-256color")
    curses.wrapper(dream)


if __name__ == "__main__":
    main()
