#!/usr/bin/env python3
"""
nix-pet-osd: PySide6 popup window for the pet.

Bound to a global keyboard shortcut. Pops up showing the pet's stats,
stage, and any pending misbehavior/present, with clickable buttons for
the common actions. Dismissable on Escape or focus loss.

Catppuccin Mocha styling, frameless window, centers on screen.

Runs the venv interpreter (~/.nix/voice/.venv) for PySide6.
"""
import json
import os
import subprocess
import sys
import time
from pathlib import Path

# Re-exec under the venv interpreter so the launcher doesn't need to know.
VENV_PY = Path.home() / ".nix" / "voice" / ".venv" / "bin" / "python3"
if VENV_PY.exists() and sys.executable != str(VENV_PY):
    os.execv(str(VENV_PY), [str(VENV_PY), __file__] + sys.argv[1:])

# Single-instance guard via PID file. Refuse to launch if already running.
PIDFILE = Path.home() / ".nix" / "voice" / ".osd.pid"
def _check_single_instance():
    if PIDFILE.exists():
        try:
            old_pid = int(PIDFILE.read_text().strip())
            os.kill(old_pid, 0)  # signal 0 = check if alive
            sys.exit(0)  # already running, bail silently
        except (OSError, ValueError):
            pass  # stale PID, fall through and overwrite
    PIDFILE.parent.mkdir(parents=True, exist_ok=True)
    PIDFILE.write_text(str(os.getpid()))
import atexit
def _cleanup_pidfile():
    try:
        if PIDFILE.exists() and int(PIDFILE.read_text().strip()) == os.getpid():
            PIDFILE.unlink()
    except Exception:
        pass
atexit.register(_cleanup_pidfile)
_check_single_instance()

from PySide6.QtCore import Qt, QTimer, QEvent
from PySide6.QtGui import QFont, QKeySequence, QShortcut, QColor
from PySide6.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QHBoxLayout, QLabel,
    QProgressBar, QPushButton, QFrame,
)

NIX_PET = Path.home() / ".nix" / "bin" / "nix-pet"
STATE_FILE = Path.home() / ".nix" / "voice" / ".pet-state"

# Catppuccin Mocha
CRUST   = "#11111b"
MANTLE  = "#181825"
BASE    = "#1e1e2e"
SURFACE = "#313244"
TEXT    = "#cdd6f4"
SUBTEXT = "#a6adc8"
MUTED   = "#7f849c"
PINK    = "#f5c2e7"
MAUVE   = "#cba6f7"
RED     = "#f38ba8"
PEACH   = "#fab387"
YELLOW  = "#f9e2af"
GREEN   = "#a6e3a1"


def run_pet(arg):
    """Run nix-pet <arg> and discard output. Used by button handlers."""
    try:
        subprocess.run([str(NIX_PET), arg], check=False,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                       timeout=4)
    except Exception:
        pass


def load_state():
    if not STATE_FILE.exists():
        return None
    try:
        return json.loads(STATE_FILE.read_text())
    except Exception:
        return None


def stage_of_state(s):
    """Replicate stage logic — keep this in sync with nix-pet."""
    age_hours = (time.time() - s.get("born", 0)) / 3600
    stages = [(0, "egg"), (6, "hatchling"), (30, "pup"), (72, "juvenile"),
              (144, "adult"), (264, "elder")]
    cur = "egg"
    for h, n in stages:
        if age_hours >= h:
            cur = n
    return cur, age_hours


def mood_label(s):
    if not s.get("alive", True):
        return "departed", MUTED
    if stage_of_state(s)[0] == "egg":
        return "incubating", YELLOW
    score = (s.get("hunger", 0) + s.get("happiness", 0)) / 2
    if score >= 70: return "thriving", PINK
    if score >= 50: return "content", MAUVE
    if score >= 30: return "okay", YELLOW
    if score >= 10: return "struggling", RED
    return "barely there", RED


class PetOSD(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowFlags(
            Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool
        )
        self.setAttribute(Qt.WA_TranslucentBackground)
        self.setFixedSize(420, 360)

        self.setStyleSheet(f"""
            QWidget#root {{
                background-color: {BASE};
                border: 1px solid {SURFACE};
                border-radius: 12px;
            }}
            QLabel#name {{ color: {TEXT}; font-size: 18pt; font-weight: 600; }}
            QLabel#stage {{ color: {MUTED}; font-size: 10pt; }}
            QLabel#row {{ color: {SUBTEXT}; font-size: 10pt; }}
            QLabel#mood {{ font-size: 10pt; font-weight: 600; }}
            QLabel#banner {{ color: {TEXT}; font-size: 9pt; padding: 8px;
                             background-color: {MANTLE}; border-radius: 6px; }}
            QProgressBar {{
                background-color: {MANTLE}; border: none; border-radius: 4px;
                height: 12px; text-align: center; color: {TEXT}; font-size: 8pt;
            }}
            QProgressBar::chunk {{ background-color: {GREEN}; border-radius: 4px; }}
            QPushButton {{
                background-color: {SURFACE}; color: {TEXT}; border: none;
                padding: 8px 12px; border-radius: 6px; font-size: 10pt;
            }}
            QPushButton:hover {{ background-color: {MAUVE}; color: {CRUST}; }}
            QPushButton:pressed {{ background-color: {PINK}; color: {CRUST}; }}
        """)

        root = QWidget(self)
        root.setObjectName("root")
        root.setGeometry(0, 0, 420, 360)
        layout = QVBoxLayout(root)
        layout.setContentsMargins(20, 18, 20, 18)
        layout.setSpacing(10)

        # Header: name + mood + close button
        head = QHBoxLayout()
        self.name_label = QLabel()
        self.name_label.setObjectName("name")
        self.mood_label = QLabel()
        self.mood_label.setObjectName("mood")
        self.mood_label.setAlignment(Qt.AlignRight | Qt.AlignVCenter)

        close_btn = QPushButton("×")
        close_btn.setFixedSize(28, 28)
        close_btn.setStyleSheet(f"""
            QPushButton {{
                background-color: transparent; color: {MUTED};
                font-size: 18pt; padding: 0; border: none;
            }}
            QPushButton:hover {{ color: {RED}; }}
        """)
        close_btn.clicked.connect(self.close)

        head.addWidget(self.name_label)
        head.addWidget(self.mood_label)
        head.addWidget(close_btn)
        layout.addLayout(head)

        self.stage_label = QLabel()
        self.stage_label.setObjectName("stage")
        layout.addWidget(self.stage_label)

        sep = QFrame()
        sep.setFrameShape(QFrame.HLine)
        sep.setStyleSheet(f"color: {SURFACE};")
        layout.addWidget(sep)

        # Stat rows
        self.hunger_bar = self._make_bar("hunger")
        self.happy_bar  = self._make_bar("happiness")
        self.bowl_bar   = self._make_bar("food bowl")
        layout.addLayout(self.hunger_bar["row"])
        layout.addLayout(self.happy_bar["row"])
        layout.addLayout(self.bowl_bar["row"])

        # Banner — misbehavior or present
        self.banner = QLabel()
        self.banner.setObjectName("banner")
        self.banner.setWordWrap(True)
        self.banner.setVisible(False)
        layout.addWidget(self.banner)

        layout.addStretch(1)

        # Buttons row 1: care
        row1 = QHBoxLayout()
        row1.addWidget(self._btn("feed",  lambda: self._do("feed")))
        row1.addWidget(self._btn("pet",   lambda: self._do("pet")))
        row1.addWidget(self._btn("walk",  lambda: self._do("walk")))
        layout.addLayout(row1)

        # Buttons row 2: response
        row2 = QHBoxLayout()
        self.scold_btn  = self._btn("scold",  lambda: self._do("scold"))
        self.thanks_btn = self._btn("thanks", lambda: self._do("thanks"))
        self.praise_btn = self._btn("praise", lambda: self._do("praise"))
        row2.addWidget(self.scold_btn)
        row2.addWidget(self.thanks_btn)
        row2.addWidget(self.praise_btn)
        layout.addLayout(row2)

        # Escape to close
        QShortcut(QKeySequence("Escape"), self, activated=self.close)

        # Auto-refresh every 2s in case of background ticks
        self.timer = QTimer(self)
        self.timer.timeout.connect(self.refresh)
        self.timer.start(2000)

        self.refresh()
        self._center()

    def _make_bar(self, label_text):
        row = QHBoxLayout()
        label = QLabel(label_text)
        label.setObjectName("row")
        label.setFixedWidth(80)
        bar = QProgressBar()
        bar.setRange(0, 100)
        bar.setValue(0)
        row.addWidget(label)
        row.addWidget(bar)
        return {"row": row, "label": label, "bar": bar}

    def _btn(self, text, handler):
        b = QPushButton(text)
        b.clicked.connect(handler)
        return b

    def _do(self, action):
        run_pet(action)
        self.refresh()

    def _center(self):
        screen = QApplication.primaryScreen().geometry()
        x = (screen.width() - self.width()) // 2
        y = (screen.height() - self.height()) // 2
        self.move(x, y)

    def refresh(self):
        s = load_state()
        if s is None:
            self.name_label.setText("no pet")
            return

        self.name_label.setText(s.get("name", "?"))
        stage_name, age_h = stage_of_state(s)
        self.stage_label.setText(f"{stage_name} · age {int(age_h)}h")

        mood, color = mood_label(s)
        self.mood_label.setText(mood)
        self.mood_label.setStyleSheet(f"color: {color}; font-size: 10pt; font-weight: 600;")

        hunger = s.get("hunger", 0)
        happy  = s.get("happiness", 0)
        bowl   = s.get("food_bowl", 0)
        self._set_bar(self.hunger_bar["bar"], hunger, 100)
        self._set_bar(self.happy_bar["bar"],  happy,  100)
        self._set_bar(self.bowl_bar["bar"],   bowl,   10)

        # Banner: show whichever is pending. Misbehavior takes priority.
        mb = s.get("recent_misbehavior")
        gp = s.get("recent_present")
        if mb:
            self.banner.setText(f"❯ {mb['msg']}")
            self.banner.setStyleSheet(self.banner.styleSheet() + f"color: {RED};")
            self.banner.setVisible(True)
            self.scold_btn.setStyleSheet("background-color: " + RED + "; color: " + CRUST + ";")
            self.thanks_btn.setStyleSheet("")
        elif gp:
            self.banner.setText(f"❯ {gp['msg']}")
            self.banner.setStyleSheet(self.banner.styleSheet() + f"color: {PEACH};")
            self.banner.setVisible(True)
            self.thanks_btn.setStyleSheet("background-color: " + PEACH + "; color: " + CRUST + ";")
            self.scold_btn.setStyleSheet("")
        else:
            self.banner.setVisible(False)
            self.scold_btn.setStyleSheet("")
            self.thanks_btn.setStyleSheet("")

    def _set_bar(self, bar, value, max_value):
        bar.setRange(0, max_value)
        bar.setValue(value)
        # Color the chunk based on percentage
        pct = (value / max_value) if max_value else 0
        if pct >= 0.6:   chunk = GREEN
        elif pct >= 0.3: chunk = YELLOW
        else:            chunk = RED
        bar.setStyleSheet(f"""
            QProgressBar {{
                background-color: {MANTLE}; border: none; border-radius: 4px;
                height: 12px; text-align: center; color: {TEXT}; font-size: 8pt;
            }}
            QProgressBar::chunk {{ background-color: {chunk}; border-radius: 4px; }}
        """)

    def changeEvent(self, event):
        # WindowDeactivate is more reliable than focusOutEvent for
        # frameless tool windows in Qt6 — fires when the window loses
        # active state, including clicking on the desktop or another window.
        if event.type() == QEvent.WindowDeactivate:
            self.close()
        super().changeEvent(event)


def main():
    app = QApplication(sys.argv)
    osd = PetOSD()
    osd.show()
    osd.raise_()
    osd.activateWindow()
    osd.setFocus()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
